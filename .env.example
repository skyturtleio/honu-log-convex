# --- Convex Self-hosted ---
# API URL (port 3210 behind proxy)
PUBLIC_CONVEX_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=
# HTTP Actions URL (port 3211 behind proxy)
PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211

# --- Logto Auth (server-side, used in src/hooks.server.ts) ---
LOGTO_ENDPOINT=http://localhost:3001
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_COOKIE_ENCRYPTION_KEY=
# API Resource (used by Convex auth + client token requests)
LOGTO_API_IDENTIFIER=https://honu-log-api.dev
PUBLIC_LOGTO_API_IDENTIFIER=https://honu-log-api.dev

# --- Convex backend environment variables (set via `bunx convex env set`, NOT here) ---
# These are set on the Convex backend, not in .env.local:
#   LOGTO_ENDPOINT=http://localhost:3001
#   LOGTO_API_IDENTIFIER=https://honu-log-api.dev
#   LOGTO_JWKS_URL=http://host.docker.internal:3001/oidc/jwks  (local dev only)
